<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion — IDF Mobilités Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        body { background: #f1f5f9; }
        .login-card { max-width: 420px; margin: 8vh auto; }
        .brand { font-size: 1.1rem; font-weight: 700; color: #1d4ed8; letter-spacing: -0.3px; }
    </style>
</head>
<body>
<div class="container login-card">
    <div class="card shadow-sm border-0">
        <div class="card-body p-5">
            <p class="brand mb-1">IDF Mobilités</p>
            <h1 class="h4 mb-4 fw-semibold">Administration</h1>
            {% if error %}
                <div class="alert alert-danger py-2">{{ error.messageKey|trans({}, "security") }}</div>
            {% endif %}
            <form method="post" action="{{ path("app_admin_login_check") }}">
                <div class="mb-3">
                    <label class="form-label fw-medium">Adresse e-mail</label>
                    <input type="email" name="_username" value="{{ last_username }}" class="form-control" autocomplete="username" autofocus>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-medium">Mot de passe</label>
                    <input type="password" name="_password" class="form-control" autocomplete="current-password">
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2">Se connecter</button>
            </form>
        </div>
    </div>
</div>
</body>
</html>
